# =============================================================================
# Sozialkonzept Schulungsplattform – Umgebungsvariablen
# Kopieren nach .env.local (lokal) bzw. in Vercel → Settings → Environment Variables
# =============================================================================

# --- Pflicht: Supabase PostgreSQL ---
# Supabase → Project Settings → Database → Connection string → URI
# Für Vercel/Serverless: „Transaction pooler“ (Port 6543) verwenden
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Optional: Direkte Verbindung (Migrationen, lokale Tools, Port 5432)
# DIRECT_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# --- Pflicht in Produktion: Session-Verschlüsselung ---
# Mindestens 32 Zeichen, zufällig generieren (z. B. openssl rand -base64 32)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# --- Pflicht in Produktion: Öffentliche App-URL ---
# Wird für Zertifikat-QR-Codes und Verifikationslinks verwendet
APP_URL=https://ihre-app.vercel.app

# --- Optional: Supabase API (für spätere Erweiterungen) ---
# Supabase → Project Settings → API
# NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Node ---
NODE_ENV=development
